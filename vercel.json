{
  "version": 2,
  "builds": [
    {
      "src": "api/health.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": ["**/*.py", "research_config.json"]
      }
    },
    {
      "src": "api/meta.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": ["**/*.py", "research_config.json"]
      }
    },
    {
      "src": "api/analyze.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": ["**/*.py", "research_config.json"]
      }
    },
    {
      "src": "api/autofill.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": ["**/*.py", "**/*.json", "research_config.json"],
        "maxDuration": 25
      }
    },
    {
      "src": "api/company-profiles.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": ["**/*.py", "research_config.json"]
      }
    },
    {
      "src": "api/signals.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": ["**/*.py", "**/*.json", "research_config.json"],
        "maxDuration": 60
      }
    },
    {
      "src": "api/pipeline.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": ["**/*.py", "**/*.json", "research_config.json"]
      }
    },
    {
      "src": "api/pricing.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": ["**/*.py", "pricing/parameters.json"],
        "maxDuration": 30
      }
    },
    {
      "src": "api/outreach.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": ["**/*.py", "**/*.json"],
        "maxDuration": 45
      }
    },
    {
      "src": "api/commerce_funding.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": ["**/*.py", "**/*.json"],
        "maxDuration": 45
      }
    },
    {
      "src": "api/commerce_dashboard.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": ["**/*.py", "**/*.json"]
      }
    },
    {
      "src": "api/commerce_proposal.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": ["**/*.py", "**/*.json", "templates/*.html"],
        "maxDuration": 15
      }
    },
    {
      "src": "api/commerce_metrics.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": ["**/*.py", "**/*.json"]
      }
    },
    {
      "src": "api/commerce_alerts.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": ["**/*.py", "**/*.json"]
      }
    },
    {
      "src": "startup_shield_web/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "startup_shield_web/app.js",
      "use": "@vercel/static"
    },
    {
      "src": "startup_shield_web/styles.css",
      "use": "@vercel/static"
    },
    {
      "src": "startup_shield_web/email-template-signal-outreach.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/health",
      "dest": "/api/health.py"
    },
    {
      "src": "/api/meta",
      "dest": "/api/meta.py"
    },
    {
      "src": "/api/analyze",
      "dest": "/api/analyze.py"
    },
    {
      "src": "/api/autofill",
      "dest": "/api/autofill.py"
    },
    {
      "src": "/api/company-profiles",
      "dest": "/api/company-profiles.py"
    },
    {
      "src": "/api/signals",
      "dest": "/api/signals.py"
    },
    {
      "src": "/api/pipeline(.*)",
      "dest": "/api/pipeline.py"
    },
    {
      "src": "/api/pricing",
      "dest": "/api/pricing.py"
    },
    {
      "src": "/api/outreach",
      "dest": "/api/outreach.py"
    },
    {
      "src": "/api/commerce/funding",
      "dest": "/api/commerce_funding.py"
    },
    {
      "src": "/api/commerce/dashboard",
      "dest": "/api/commerce_dashboard.py"
    },
    {
      "src": "/api/commerce/proposal",
      "dest": "/api/commerce_proposal.py"
    },
    {
      "src": "/api/commerce/metrics",
      "dest": "/api/commerce_metrics.py"
    },
    {
      "src": "/api/commerce/alerts",
      "dest": "/api/commerce_alerts.py"
    },
    {
      "src": "/app.js",
      "dest": "/startup_shield_web/app.js"
    },
    {
      "src": "/styles.css",
      "dest": "/startup_shield_web/styles.css"
    },
    {
      "src": "/email-template-signal-outreach.html",
      "dest": "/startup_shield_web/email-template-signal-outreach.html"
    },
    {
      "src": "/",
      "dest": "/startup_shield_web/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/startup_shield_web/index.html"
    }
  ]
}
